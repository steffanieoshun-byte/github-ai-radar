GITHUB_TOKEN=
ANALYZER_MODE=mock
DATABASE_PATH=data/radar.sqlite3

# 可选：OpenAI 或任意 OpenAI-compatible 模型接口。
# ANALYZER_MODE=llm 时启用；不填则自动使用本地 MockAnalyzer。
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# 可选：备用模型接口，主接口额度不足或失败时按顺序尝试。
LLM_FALLBACK_1_API_KEY=
LLM_FALLBACK_1_BASE_URL=
LLM_FALLBACK_1_MODEL=
LLM_FALLBACK_2_API_KEY=
LLM_FALLBACK_2_BASE_URL=
LLM_FALLBACK_2_MODEL=
LLM_FALLBACK_3_API_KEY=
LLM_FALLBACK_3_BASE_URL=
LLM_FALLBACK_3_MODEL=

# 兼容 OpenAI 官方接口时也可以填 OPENAI_API_KEY，
# 但仍建议显式填写 LLM_MODEL。
OPENAI_API_KEY=
